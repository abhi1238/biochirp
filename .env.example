# ===============================
# BioChirp Environment Template
# ===============================
# Copy to .env and fill with real values.
# Do NOT commit secrets.

# ---------- API Keys ----------
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
GROK_KEY=your_grok_api_key
# Optional compatibility variable used by some components
GROK_API_KEY=your_grok_api_key
TAVILY_API_KEY=your_tavily_api_key

# ---------- Core Model Selection ----------
INTERPRETER_MODEL_NAME=gpt-4.1-mini
INTERPRETER_AGENT_SCHEMA_MAPPER_MODEL_NAME=gpt-4.1-mini
ORCHESTRATOR_MODEL_NAME=gpt-4.1-mini
SUMMARIZER_MODEL_NAME=gpt-4.1-nano
WEB_MODEL_NAME=gpt-4o-mini
LLM_FILTER_MODEL_NAME=gpt-4o-mini
SEMANTIC_MATCHING_MODEL_NAME=gpt-4.1-nano

# ---------- Runtime & Timeouts ----------
USE_THREAD_WRAPPER=False
AGENT_TIMEOUT_SEC=90
ROUTE_TIMEOUT_SEC=120
MAX_TIMEOUT=120
OPENAI_HTTP_TIMEOUT=45
WEB_TIMEOUT_SEC=90
WEB_TOOL_TIMEOUT=30

# ---------- Matching Controls ----------
FUZZY_SCORE_CUT_SCORE=90
# Legacy variable still present in older paths
FUZZY_SEARCH_CUT_OFF=90
USE_KNEE_CUT_OFF=True
KNEE_CUT_OFF=0.50

# ---------- Graph Planner Controls ----------
# Active in current planner implementation:
MAX_TABLES_IN_COVERAGE=20
STEINER_TIMEOUT_SECONDS=300
# Legacy/no-op in current deterministic Steiner planner path:
USE_GREEDY_ALGORITHM=true
MAX_COMBINATIONS=10000

# ---------- Join Execution Safety ----------
STRICT_JOIN_MODE=true
CROSS_JOIN_THRESHOLD=5000
MAX_RESULT_SIZE=10000000
MAX_UNIQUE_ROWS=1000000

# ---------- Preview / Output ----------
HEAD_VIEW_ROW_COUNT=50
OT_PREVIEW_ROWS=50

# ---------- Optional DB-related vars ----------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres

# Optional explicit DB labels/paths used in some scripts
TTD_DB_NAME=ttd
CTD_DB_NAME=ctd
HCDT_DB_NAME=hcdt

TTD_DB_PATH=database/ttd
CTD_DB_PATH=database/ctd
HCDT_DB_PATH=database/hcdt
